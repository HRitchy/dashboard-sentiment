# Copier ce fichier en .env.local et renseigner les valeurs.
# .env.local n'est pas commité (voir .gitignore).

# Clé API Anthropic — utilisée par /api/ai/verdict et /api/ai/sp500.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Clé FRED (HY OAS, NFCI). Optionnelle : un fallback public est utilisé sinon.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
